{
  "name": "fade",
  "version": "1.0.0",
  "description": "Faint Aura - Development Experiment",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.hidesun1372.fade",
    "productName": "FADE",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico"
    },
    "files": [
      "main.js",
      "loading.html",
      "mus_start.mp3",
      "mus_startlong.mp3",
      "!dist/**"
    ]
  }
}
