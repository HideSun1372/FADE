{
  "name": "fade",
  "version": "1.0.0",
  "description": "Faint Aura - Development Experiment",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0"
  },
  "build": {
    "appId": "com.hidesun1372.fade",
    "productName": "FADE",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "favicon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "favicon.ico",
      "uninstallerIcon": "favicon.ico"
    },
    "files": [
      "main.js",
      "loading.html",
      "!dist/**"
    ],
    "extraResources": [
      { "from": "resources/jre", "to": "jre" },
      { "from": "resources/app.jar", "to": "app.jar" }
    ]
  }
}
